# =============================================================================
# VERCEL — Projeto: rom-club-iguatemi (Production)
# Cole cada variável em Settings → Environment Variables → Production
# NUNCA copie DATABASE_URL ou AVEC_API_TOKEN do projeto rom-club-brasil
# =============================================================================

ROM_PANEL=iguatemi
NEXT_PUBLIC_ROM_PANEL=iguatemi
ROM_SEED_PRESET=iguatemi

# Neon — projeto dedicado rom-club-iguatemi (criar em console.neon.tech)
DATABASE_URL=

# Logins Iguatemi — gere senhas fortes e únicas por role/projeto
ROM_ADMIN_USER=admin
ROM_ADMIN_PASSWORD=
ROM_STAFF_USER=EQUIPE-IGUATEMI
ROM_STAFF_PASSWORD=
ROM_FINANCE_USER=FINANCEIRO-IGUATEMI
ROM_FINANCE_PASSWORD=
ROM_STOCK_USER=ESTOQUE-IGUATEMI
ROM_STOCK_PASSWORD=
# Legado/header token: deixe vazio salvo necessidade operacional explícita.
ROM_ACCESS_TOKEN=

# Segredo NOVO — não reutilize o CRON_SECRET do Brasil
# Gerar: openssl rand -hex 32
CRON_SECRET=

# Avec — token EXCLUSIVO da loja Iguatemi
AVEC_API_URL=https://api.avec.beauty
AVEC_API_TOKEN=
AVEC_SYNC_MAX_PAGES=200
AVEC_WEBHOOK_SECRET=

# Claude — pode ser a mesma ANTHROPIC_API_KEY do Brasil
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# WhatsApp — instância e número da unidade Iguatemi
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=rom-iguatemi
WHATSAPP_WEBHOOK_SECRET=

# Telegram — bot dedicado Iguatemi (criar via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STAFF_CHAT_IDS=

# =============================================================================
# Webhooks (após domínio configurado)
# WhatsApp: https://SEU-DOMINIO-IGUATEMI/api/webhooks/whatsapp
# Telegram: https://SEU-DOMINIO-IGUATEMI/api/webhooks/telegram
# Avec:    https://SEU-DOMINIO-IGUATEMI/api/webhooks/avec
# =============================================================================
