# =============================================================================
# GABRIEL VITRINI — variáveis da instância independente
# =============================================================================
# Template Vercel: deploy/vercel-gabriel-vitrini.env
# Guia: deploy/SETUP-GABRIEL-VITRINI.md
# =============================================================================

# --- Neon (1 banco POR projeto Vercel) ---
DATABASE_URL=
# Pipeline de schema (db/migrations.json) — roda no boot nodejs e via:
#   npm run db:migrate
#   POST /api/admin/migrations
# ROM_SKIP_BOOT_MIGRATIONS=1

# --- Painel desta instância (mesmo valor nos dois campos) ---
ROM_PANEL=vitrini
NEXT_PUBLIC_ROM_PANEL=vitrini
ROM_SEED_PRESET=vitrini
# Meta de faturamento diário (R$) — KPI "Meta do dia" em intelligence.ts
SALON_DAILY_GOAL=5000

# Sentry (Next.js) — DSN do projeto desta unidade na org imobi-hl
NEXT_PUBLIC_SENTRY_DSN=
# Opcional — upload de source maps no build (nunca commitar)
# SENTRY_AUTH_TOKEN=

# IA — pode ser a mesma chave Anthropic nos dois projetos (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# WhatsApp — 1 instância Evolution POR unidade (número diferente)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
WHATSAPP_WEBHOOK_SECRET=

# Telegram — 1 bot POR unidade (recomendado)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STAFF_CHAT_IDS=

# Telegram — bot dedicado do financeiro (terceiro bot, separado do da equipe)
# Comandos: /financeiro (receita/despesas/margem) e /estoque (valor + alertas)
TELEGRAM_FINANCE_BOT_TOKEN=
TELEGRAM_FINANCE_WEBHOOK_SECRET=
TELEGRAM_FINANCE_CHAT_IDS=

# App do profissional (/pro) — segredo único; não reutilize CRON_SECRET
PRO_DATA_SECRET=
# Telegram do assinante (bot separado do staff ROM; fallback = TELEGRAM_BOT_TOKEN)
TELEGRAM_PRO_BOT_TOKEN=
TELEGRAM_PRO_WEBHOOK_SECRET=
TELEGRAM_PRO_BOT_USERNAME=

# Trinks (Conecta) — API Key do assinante; mock com token "mock" ou TRINKS_MOCK=1
TRINKS_API_URL=https://api.trinks.com
TRINKS_MOCK=
TRINKS_ESTABELECIMENTO_ID=

# WhatsApp Cloud do assinante Pro — webhook /api/webhooks/whatsapp-pro
WHATSAPP_CLOUD_MOCK=
WHATSAPP_PRO_VERIFY_TOKEN=
WHATSAPP_PRO_APP_SECRET=
WHATSAPP_TEMPLATE_REMINDER=lembrete_horario
WHATSAPP_TEMPLATE_REACTIVATION=reativacao_cliente
# Meta Embedded Signup (opcional — botão em /pro/conectar)
META_APP_ID=
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Demo: cadastro sem Stripe + upgrade demo (também liberado fora de production)
PRO_ALLOW_SELF_UPGRADE=
PRO_ALLOW_PACK_PURCHASE=

# Stripe — assinaturas HairSales (Standard R$29,90 + Pro R$199,90) + packs
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
# Customer Portal (faturas / cartão / cancelar) — gere com: npm run stripe:portal
STRIPE_PORTAL_CONFIGURATION_ID=
NEXT_PUBLIC_APP_URL=




# Avec — TOKEN DIFERENTE por unidade (API da loja Brasil ≠ Iguatemi)
# Painel ROM da unidade (não é o token do assinante B2C — esse vai em Conectar)
AVEC_API_URL=https://api.avec.beauty
AVEC_API_TOKEN=
# ID da unidade no painel Avec — escopa o sync (evita misturar unidades se o token for compartilhado)
AVEC_UNIT_ID=
AVEC_SYNC_MAX_PAGES=
# Override do relatório 0011 (diretoria); padrão = 0011
AVEC_REPORT_DIRECTOR_RETURN=
# Override do relatório 0081 (formas de pagamento no Financeiro); padrão = 0081
AVEC_REPORT_PAYMENT_MIX=
# Tempo real — URL: https://SEU-DOMINIO/api/webhooks/avec  Header: x-avec-secret
AVEC_WEBHOOK_SECRET=

# Cron — segredo ÚNICO por projeto Vercel (evita que um cron dispare no outro)
CRON_SECRET=

# =============================================================================
# ROLES & ACCESS CONTROL
# =============================================================================
# Each role has specific dashboard access and is isolated from others.
# See src/middleware.ts for isolation logic.
#
# LOGIN — password PER unit/role (recommended to rotate monthly)
# If a ROM_*_PASSWORD is missing or blank, the app falls back to the legacy shared
# default (Senha@123) for backwards compatibility. Set every role password in env
# before/while rotating production deploys.
#
# Admin: Full access (all dashboards + admin panel)
ROM_ADMIN_USER=ADMIN-VITRINI
ROM_ADMIN_PASSWORD=Senha@123
# Access: /, /hoje, /dashboard, /admin, /contatos, /financeiro, /estoque, /onboarding
#
# Staff: Operational panel access; not admin-only, but no financials or inventory.
ROM_STAFF_USER=EQUIPE-VITRINI
ROM_STAFF_PASSWORD=Senha@123
# Access: /, /hoje, /dashboard, /contatos, /admin, /onboarding (no financeiro, estoque)
#
# Finance (Financeiro): Financial dashboard + dual access to stock
ROM_FINANCE_USER=FINANCEIRO-VITRINI
ROM_FINANCE_PASSWORD=Senha@123
# Access: /financeiro, /estoque (duplo), /onboarding (não: hoje, dashboard, contatos, admin)
# Note: Financeiro cuida de AMBOS financeiro e estoque
#
# Stock (Estoque): Inventory management (isolated from finance & other areas)
ROM_STOCK_USER=ESTOQUE-VITRINI
ROM_STOCK_PASSWORD=Senha@123
# Access: /estoque, /onboarding only (não: financeiro, hoje, dashboard, contatos, admin)
# Note: Estoque é isolado — nunca vê financeiro ou operações gerais
#
ROM_ACCESS_TOKEN=Senha@123

# Demo Avec sem token (só desenvolvimento)
AVEC_MOCK=

# Relatório diretoria (terça 08:00) — e-mail via Resend
RESEND_API_KEY=
DIRECTOR_REPORT_EMAIL=
# DIRECTOR_REPORT_FROM=GABRIEL VITRINI <onboarding@resend.dev>

# Split fiscal (CBS/IBS) — conciliação no Financeiro (consumidor, não PSP)
# Feed merchant/sandbox ou export do PSP no formato da Plataforma Pública (RFB/CGIBS)
FISCAL_SPLIT_API_URL=
FISCAL_SPLIT_API_KEY=
FISCAL_SPLIT_ENV=sandbox
FISCAL_SPLIT_TIMEOUT_MS=15000
# FISCAL_SPLIT_MOCK=1


# =============================================================================
# EXEMPLO — Projeto Vercel "gabriel-vitrini" (Production)
# =============================================================================
# ROM_PANEL=vitrini
# NEXT_PUBLIC_ROM_PANEL=vitrini
# ROM_SEED_PRESET=vitrini
# DATABASE_URL=postgresql://...neon...vitrini...   ← banco dedicado
# AVEC_API_TOKEN=token_da_unidade_vitrini
# AVEC_UNIT_ID=id_da_unidade_vitrini
# EVOLUTION_API_INSTANCE=gabriel-vitrini
# CRON_SECRET=(openssl rand -hex 32)
# Webhooks apontam para https://SEU-DOMINIO/api/webhooks/...
# =============================================================================
