# =============================================================================
# ROM — variáveis por instância (Brasil e Iguatemi são INDEPENDENTES)
# =============================================================================
# Templates prontos para colar na Vercel:
#   deploy/vercel-rom-club-brasil.env
#   deploy/vercel-rom-club-iguatemi.env
# Guia Iguatemi: deploy/SETUP-IGUATEMI.md
# =============================================================================

# --- Neon (1 banco POR projeto Vercel) ---
DATABASE_URL=

# --- Painel desta instância (mesmo valor nos dois campos) ---
ROM_PANEL=brasil
NEXT_PUBLIC_ROM_PANEL=brasil
ROM_SEED_PRESET=brasil
# Meta de faturamento diário (R$) — KPI "Meta do dia" em intelligence.ts
SALON_DAILY_GOAL=5000

# Sentry (Next.js) — DSN do projeto desta unidade na org imobi-hl
NEXT_PUBLIC_SENTRY_DSN=
# Opcional — upload de source maps no build (nunca commitar)
# SENTRY_AUTH_TOKEN=

# IA — pode ser a mesma chave Anthropic nos dois projetos (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# WhatsApp — 1 instância Evolution POR unidade (número diferente)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
WHATSAPP_WEBHOOK_SECRET=

# Telegram — 1 bot POR unidade (recomendado)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STAFF_CHAT_IDS=

# Avec — TOKEN DIFERENTE por unidade (API da loja Brasil ≠ Iguatemi)
AVEC_API_URL=https://api.avec.beauty
AVEC_API_TOKEN=
# ID da unidade no painel Avec — escopa o sync (evita misturar unidades se o token for compartilhado)
AVEC_UNIT_ID=
AVEC_SYNC_MAX_PAGES=
# Override do relatório 0011 (diretoria); padrão = 0011
AVEC_REPORT_DIRECTOR_RETURN=
# Tempo real — URL: https://SEU-DOMINIO/api/webhooks/avec  Header: x-avec-secret
AVEC_WEBHOOK_SECRET=

# Cron — segredo ÚNICO por projeto Vercel (evita que um cron dispare no outro)
CRON_SECRET=

# Login — senha POR unidade (recomendado)
# Admin: painel completo (inclui faturamento)
ROM_ADMIN_USER=ADMIN-BRASIL
ROM_ADMIN_PASSWORD=
# Funcionário: painel completo SEM faturamento
ROM_STAFF_USER=FUNC-BRASIL
ROM_STAFF_PASSWORD=
# Financeiro: painel próprio e isolado (/financeiro) — não vê contatos, hoje, dashboard
ROM_FINANCE_USER=FINANCEIRO-BRASIL
ROM_FINANCE_PASSWORD=
ROM_ACCESS_TOKEN=

# Demo Avec sem token (só desenvolvimento)
AVEC_MOCK=

# Relatório diretoria (terça 08:00) — e-mail via Resend
RESEND_API_KEY=
DIRECTOR_REPORT_EMAIL=contato.vinicaetano93@gmail.com
# DIRECTOR_REPORT_FROM=ROM CLUB BRASIL <onboarding@resend.dev>


# =============================================================================
# EXEMPLO — Projeto Vercel "rom-club-iguatemi" (Production)
# =============================================================================
# ROM_PANEL=iguatemi
# NEXT_PUBLIC_ROM_PANEL=iguatemi
# ROM_SEED_PRESET=iguatemi
# DATABASE_URL=postgresql://...neon...iguatemi...   ← banco dedicado
# AVEC_API_TOKEN=token_da_loja_iguatemi              ← token Avec Iguatemi
# EVOLUTION_API_INSTANCE=rom-iguatemi
# CRON_SECRET=(openssl rand -hex 32)                 ← diferente do Brasil
# Webhooks apontam para https://iguatemi.romclub.com.br/api/webhooks/...
# =============================================================================
