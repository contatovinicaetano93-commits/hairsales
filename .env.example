# Neon (Postgres) — projeto dedicado ao ROM. Connection string com sslmode=require.
DATABASE_URL=

# IA — Claude (Anthropic): briefings, WhatsApp e Telegram
ANTHROPIC_API_KEY=
# Opcional — padrão: claude-sonnet-4-6. Para economizar: claude-3-5-haiku-latest
ANTHROPIC_MODEL=

# WhatsApp — Evolution API (instância própria, self-hosted ou provedor gerenciado)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
# Secret no header x-whatsapp-secret ou x-webhook-secret — obrigatório em produção
WHATSAPP_WEBHOOK_SECRET=

# Telegram — bot dedicado ao ROM, criado via @BotFather
TELEGRAM_BOT_TOKEN=
# Secret que você define no setWebhook do Telegram (secret_token) — obrigatório em produção
TELEGRAM_WEBHOOK_SECRET=
# Chat IDs da equipe (separados por vírgula) — restrinja o bot e receba alertas de handoff
TELEGRAM_STAFF_CHAT_IDS=

# Avec — API de Relatórios (Postman: documenter.getpostman.com/view/12527228/2sA2xmUWJo)
# Base padrão: https://api.avec.beauty (só mude AVEC_API_URL se o suporte indicar outra)
AVEC_API_URL=https://api.avec.beauty
# Token gerado no painel Avec — vai direto no header Authorization (sem "Bearer")
AVEC_API_TOKEN=
# Máx. páginas por relatório no sync (padrão 200 → até ~50.000 clientes). Máximo: 500
AVEC_SYNC_MAX_PAGES=
# Webhook push (opcional): segredo no header x-avec-secret — obrigatório se usar webhook
AVEC_WEBHOOK_SECRET=

# Vercel Cron — protege POST /api/avec/sync (Bearer token) — obrigatório em produção
CRON_SECRET=

# Login do painel — protege dashboard, contatos, hoje e APIs internas
ROM_ADMIN_USER=admin
ROM_ADMIN_PASSWORD=
# Legado (opcional): se ROM_ADMIN_PASSWORD vazio, usa este valor como senha única
ROM_ACCESS_TOKEN=

# Painel ativo: brasil (ROM CLUB BRASIL) ou iguatemi (ROM CLUB IGUATEMI)
# Defina ROM_PANEL no servidor e NEXT_PUBLIC_ROM_PANEL no build (mesmo valor)
ROM_PANEL=brasil
NEXT_PUBLIC_ROM_PANEL=brasil
# Preset padrão do seed quando não informado no POST /api/seed (brasil | iguatemi)
ROM_SEED_PRESET=brasil

# Modo demo Avec — sync com dados fictícios sem token real
AVEC_MOCK=
